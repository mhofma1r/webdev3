#!/usr/bin/env bash
set -euo pipefail

CODEX_PROJECT_DIR="/home/webuser/.project"
PROJECT_MANAGER_DIR="/var/www/.project"

CONTEXT_FILE="$(mktemp)"

cleanup() {
    rm -f "$CONTEXT_FILE"
}
trap cleanup EXIT

append_file() {
    local title="$1"
    local file="$2"

    if [ -f "$file" ]; then
        {
            echo
            echo "========================================"
            echo "$title"
            echo "SOURCE: $file"
            echo "========================================"
            echo
            cat "$file"
            echo
        } >> "$CONTEXT_FILE"
    fi
}

append_file "AGENT IDENTITY AND WORKFLOW" "$CODEX_PROJECT_DIR/AGENTS.md"
append_file "DEVELOPMENT PREFERENCES" "$CODEX_PROJECT_DIR/DEVELOPMENT_PREFERENCES.md"
append_file "PROJECT MANAGER OVERVIEW" "$PROJECT_MANAGER_DIR/README.md"
append_file "DEVELOPMENT NOTES" "$CODEX_PROJECT_DIR/DEVELOPMENT_NOTES.md"

cat >> "$CONTEXT_FILE" <<'EOF'

========================================
MANDATORY SESSION INSTRUCTIONS
========================================

You must read the context above before doing project work.

You are expected to keep DEVELOPMENT_NOTES.md up to date.

When you discover important information, limitations, security concerns, architectural decisions, unresolved questions, or future work, update:

/home/webuser/.project/DEVELOPMENT_NOTES.md

Clearly mark important questions or warnings for Michael so they are easy to notice when scrolling the file.

Do not over-engineer. Keep Michael focused on core technology required for the project.
Avoid spending time on speculative features unless they are clearly needed.

EOF

USER_PROMPT="$*"

exec codex \
  --sandbox danger-full-access \
  --ask-for-approval on-request \
  --config model_reasoning_effort="high" \
  "$(cat "$CONTEXT_FILE")

========================================
MICHAEL'S REQUEST
========================================

$USER_PROMPT"